    {
      "name": "Notes",
      "item": [
        {
          "name": "Create Note (Teacher/Director)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenTeacher}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": {{studentId}},\n  \"title\": \"Recado\",\n  \"content\": \"Aluno participou bem da atividade.\",\n  \"type\": \"GENERAL\",\n  \"visibleToResponsible\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/notes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes"
              ]
            }
          }
        },
        {
          "name": "Update Note (Teacher/Director)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenTeacher}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Conteudo atualizado.\",\n  \"status\": \"RESOLVED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/notes/{{noteId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "{{noteId}}"
              ]
            }
          }
        },
        {
          "name": "Delete Note (Teacher/Director)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenTeacher}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes/{{noteId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "{{noteId}}"
              ]
            }
          }
        },
        {
          "name": "List Notes by Student (Director)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenDirector}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes/student/{{studentId}}?status=OPEN",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "student",
                "{{studentId}}"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "OPEN"
                }
              ]
            }
          }
        },
        {
          "name": "List Notes by Student (Responsible)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenResponsible}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notes/student/{{studentId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "notes",
                "student",
                "{{studentId}}"
              ]
            }
          }
        }
      ]
    },
